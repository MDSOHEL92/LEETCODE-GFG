class Solution {
  public:
    bool isPower(int x, int y) {
        // code here
        if(x == 1) return y == 1;
        if(y == 1) return true;
        
        long long pow = 1;
        while(pow < y){
            pow *= x;
            if(pow == y) return true;
        }
        return pow == y;
    }
};
