class Solution:
    def isGood(self, nums: List[int]) -> bool:
        n = len(nums) - 1
        if n < 1:
            return False

        cnt = [0] * (n + 1)

        for x in nums:
            if x < 1 or x > n:
                return False
            cnt[x] += 1
        for i in range(1, n):
            if cnt[i]!= 1:
                return False
        return cnt[n] == 2
        
