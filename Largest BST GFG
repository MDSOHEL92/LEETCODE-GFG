/* Tree node structure  used in the program

struct Node {
    int data;
    Node *left;
    Node *right;

    Node(int val) {
        data = val;
        left = right = NULL;
    }
};*/

class Solution {
  public:
    /*You are required to complete this method */
    // Return the size of the largest sub-tree which is also a BST
    int largestBst(Node *root) {
        // Your code here
        int maxSize = 0;
        largestBstutil(root, maxSize);
        return maxSize;
    }
    
    vector<int> largestBstutil(Node* root, int &maxSize){
        if(root == NULL)
            return {1, INT_MAX, INT_MIN, 0};
            
        vector<int> left = largestBstutil(root->left, maxSize);
        vector<int> right = largestBstutil(root->right, maxSize);
        
        vector<int> curr(4);
        curr[3] = left[3] + right[3] + 1;
        
        if(left[0] && right[0] && root->data > left[2] && root->data < right[1]){
            curr[0] = 1;
            curr[1] = min(root->data, left[1]);
            curr[2] = max(root->data, right[2]);
            
            maxSize = max(maxSize, curr[3]);
        }else{
            curr[0] = 0;
            curr[1] = INT_MIN;
            curr[2] = INT_MAX;
        }
        return curr;
        
    }
};
