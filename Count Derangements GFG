class Solution {
  public:
    int derangeCount(int n) {
        // code here
        if (n == 1) return 0;
        if (n == 2) return 1;
        
        long long prev2 = 0;
        long long prev1 = 1;
        long long curr;
        
        for(int i=3; i<=n; i++){
            curr = (i - 1) * (prev1 + prev2);
            prev2 = prev1;
            prev1 = curr;
        }
        return prev1;
    }
};
