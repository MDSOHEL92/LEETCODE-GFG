class Solution:
    def findCoverage(self, mat):
        rows, cols = len(mat), len(mat[0])
        total = 0
        
        for i in range(rows):
            for j in range(cols):
                if mat[i][j] == 0:
                    # check up
                    if i > 0 and mat[i-1][j] == 1: total += 1
                    # check down 
                    if i < rows-1 and mat[i+1][j] == 1: total += 1
                    # check left
                    if j > 0 and mat[i][j-1] == 1: total += 1
                    # check right
                    if j < cols-1 and mat[i][j+1] == 1: total += 1
        
        return total
