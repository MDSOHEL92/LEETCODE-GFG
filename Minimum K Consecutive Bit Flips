class Solution {
  public:
    int kBitFlips(vector<int>& arr, int k) {
        // code here
        int n = arr.size(), flips = 0;
        queue<int> q;
        for(int i=0; i<n; ++i){
            if(!q.empty() && i >= q.front() + k) q.pop();
            if((arr[i] + q.size()) % 2 == 0){
                if(i + k > n) return -1;
                flips++;
                q.push(i);
            }
        }
        return flips;
    }
};
