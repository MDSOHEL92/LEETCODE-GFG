class Solution:
    def kSubstr(self, s: str, k: int) -> bool:
        # code here1
        n = len(s)
        if n % k!= 0:
            return False
            
        m = n // k
        freq = {}
        
        for i in range(0, n, k):
            block = s[i:i+k]
            freq[block] = freq.get(block, 0) + 1
            
        max_freq = max(freq.values())
        return max_freq >= m - 1
