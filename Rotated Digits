class Solution:
    def rotatedDigits(self, n: int) -> int:
        valid_same = {'0', '1', '8'}
        valid_diff = {'2', '5', '6', '9'}
        invalid = {'3', '4', '7'}
        count = 0

        for num in range(1, n + 1):
            digits = set(str(num))
            if digits & invalid:
                continue
            if digits & valid_diff:
                count += 1

        return count
