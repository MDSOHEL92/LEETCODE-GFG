'''
class Node:
    def __init__(self, val):
        self.data = val
        self.right = None
        self.left = None
'''

class Solution:
    def countAllPaths(self, root, k):
        # code h
        self.count = 0
        self.helper(root, k, [])
        return self.count
        
    def helper(self, node, k, path):
        if not node:
            return
        path.append(node.data)
        self.check_path_sum(path, k)
        self.helper(node.left, k, path)
        self.helper(node.right, k, path)
        path.pop()
        
    def check_path_sum(self, path, k):
        curr_sum = 0
        for i in range(len(path)-1, -1, -1):
            curr_sum += path[i]
            if curr_sum == k:
                self.count += 1
