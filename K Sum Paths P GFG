class Solution {
  public:
    void dfs(Node* node, long long currSum, int k,
             unordered_map<long long,int>& mp, int &cnt){
        
        if(!node) return;
        
        currSum += node->data;
        
        if(currSum == k)
            cnt++;
        
        if(mp.find(currSum - k) != mp.end())
            cnt += mp[currSum - k];
        
        mp[currSum]++;
        
        dfs(node->left, currSum, k, mp, cnt);
        dfs(node->right, currSum, k, mp, cnt);
        
        mp[currSum]--;
    }

    int countAllPaths(Node *root, int k) {
        unordered_map<long long,int> mp;
        int cnt = 0;
        
        dfs(root, 0, k, mp, cnt);
        
        return cnt;
    }
};
