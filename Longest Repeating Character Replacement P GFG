class Solution:
    def longestSubstr(self, s, k):
        # Code here
        from collections import defaultdict
        freq = defaultdict(int)
        left = max_freq = ans = 0
        
        for right, ch in enumerate(s):
            freq[ch] += 1
            max_freq = max(max_freq, freq[ch])
            
            while(right - left + 1) - max_freq > k:
                freq[s[left]] -= 1
                left += 1
                
            ans = max(ans, right - left + 1)
        return ans
