class Solution {
  public:
    int totalWays(vector<int>& arr, int target) {
        //  code here
        unordered_map<string, int> memo;
        return dfs(arr, target, 0, 0, memo);
    }
    private:
        int dfs(vector<int> & arr, int target, int index, int sum,
        unordered_map<string, int> memo ){
            string key = to_string(index) + " -" + to_string(sum);
            if(memo.count(key)) return memo[key];
            if(index == arr.size()) return (sum == target) ? 1 : 0;
            
            int add = dfs(arr, target, index + 1, sum + arr[index], memo);
            int subtract = dfs(arr, target, index + 1, sum - arr[index], memo);
            
            memo[key] = add + subtract;
            return memo[key];
        }
};
