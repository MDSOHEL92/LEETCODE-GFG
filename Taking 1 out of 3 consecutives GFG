
class Solution {
  public:
    int minSum(vector<int>& arr) {
        // Write your code here
        int n = arr.size();
        if(n < 3) return 0;
        
        vector<int> dp(n, INT_MAX);
        dp[0] = arr[0];
        dp[1] = arr[1];
        dp[2] = arr[2];
        
        for(int i =3; i<n; i++){
            dp[i] = arr[i] + min({dp[i-3], dp[i-2], dp[i-1]});
        }
        return min({dp[n-1], dp[n-2], dp[n-3]});
    }
};
